-+// wsPipe creates a pair of connected net.Conns using a real TCP listener.
-+func wsPipe(t *testing.T) (client, server net.Conn) {
-+	t.Helper()
-+	ln, err := net.Listen("tcp", "127.0.0.1:0")
-+	if err != nil {
-+		t.Fatal(err)
-+	}
-+	t.Cleanup(func() { ln.Close() })
-+
-+	ch := make(chan net.Conn)
-+	go func() {
-+		conn, err := ln.Accept()
-+		if err != nil {
-+			close(ch)
-+			return
-+		}
-+		ch <- conn
-+	}()
-+
-+	client, err = net.Dial("tcp", ln.Addr().String())
-+	if err != nil {
-+		t.Fatal(err)
-+	}
-+	server = <-ch
-+	if server == nil {
-+		t.Fatal("server accept failed")
-+	}
-+	t.Cleanup(func() { client.Close() })
-+	t.Cleanup(func() { server.Close() })
-+	return client, server
-+}
-+
-+// writeTextFrame writes a raw WebSocket text frame (unmasked, server-to-client).
-+func writeTextFrame(conn net.Conn, payload string) {
-+	frame := []byte{0x81} // FIN + text opcode
-+	n := len(payload)
-+	if n <= 125 {
-+		frame = append(frame, byte(n))
-+	} else if n <= 65535 {
-+		frame = append(frame, 126, byte(n>>8), byte(n))
-+	}
-+	frame = append(frame, []byte(payload)...)
-+	conn.Write(frame)
-+}
-+
-+// writeCloseFrame writes a WebSocket close frame with optional reason.
-+func writeCloseFrame(conn net.Conn, reason string) {
-+	frame := []byte{0x88} // FIN + close opcode
-+	n := len(reason)
-+	if n <= 125 {
-+		frame = append(frame, byte(n))
-+	}
-+	frame = append(frame, []byte(reason)...)
-+	conn.Write(frame)
-+}
-+
-+// writePingFrame writes a WebSocket ping frame with optional payload.
-+func writePingFrame(conn net.Conn, payload string) {
-+	frame := []byte{0x89} // FIN + ping opcode
-+	frame = append(frame, byte(len(payload)))
-+	frame = append(frame, []byte(payload)...)
-+	conn.Write(frame)
-+}
