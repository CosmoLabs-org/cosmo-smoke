+// isDockerAvailable returns true if the `docker` CLI is on PATH AND the daemon is reachable.
+func isDockerAvailable() bool {
+	if _, err := exec.LookPath("docker"); err != nil {
+		return false
+	}
+	// Quick check: `docker info` returns 0 only when daemon is reachable.
+	ctx, cancel := context.WithTimeout(context.Background(), 2*time.Second)
+	defer cancel()
+	return exec.CommandContext(ctx, "docker", "info").Run() == nil
+}
+
+func TestCheckDockerContainerRunning_NotPresent(t *testing.T) {
+	r := CheckDockerContainerRunning(&schema.DockerContainerCheck{Name: "cosmo-smoke-test-never-exists-zzz"})
+	if r.Passed {
+		t.Errorf("expected fail for nonexistent container, got pass: %+v", r)
+	}
+	if r.Type != "docker_container_running" {
+		t.Errorf("wrong type: %q", r.Type)
+	}
+}
+
+func TestCheckDockerImageExists_NotPresent(t *testing.T) {
+	r := CheckDockerImageExists(&schema.DockerImageCheck{Image: "cosmo-smoke-no-such-image:never"})
+	if r.Passed {
+		t.Errorf("expected fail for nonexistent image, got pass: %+v", r)
+	}
+	if r.Type != "docker_image_exists" {
+		t.Errorf("wrong type: %q", r.Type)
+	}
+}
+
+func TestCheckDockerContainerRunning_RealContainer(t *testing.T) {
+	if !isDockerAvailable() {
+		t.Skip("docker daemon not available")
+	}
+	// Start ephemeral container
+	name := "cosmo-smoke-test-" + fmt.Sprint(time.Now().UnixNano())
+	cmd := exec.Command("docker", "run", "-d", "--rm", "--name", name, "alpine:3.20", "sleep", "30")
+	if err := cmd.Run(); err != nil {
+		t.Skipf("cannot start test container: %v", err)
+	}
+	t.Cleanup(func() {
+		exec.Command("docker", "rm", "-f", name).Run() //nolint:errcheck
+	})
+	// Give docker a moment
+	time.Sleep(200 * time.Millisecond)
+
+	r := CheckDockerContainerRunning(&schema.DockerContainerCheck{Name: name})
+	if !r.Passed {
+		t.Errorf("expected pass for running container, got fail: %+v", r)
+	}
+}
+
+func TestCheckDockerImageExists_RealImage(t *testing.T) {
+	if !isDockerAvailable() {
+		t.Skip("docker daemon not available")
+	}
+	// Ensure the image is present
+	pull := exec.Command("docker", "pull", "alpine:3.20")
+	if err := pull.Run(); err != nil {
+		t.Skipf("cannot pull alpine:3.20: %v", err)
+	}
+
+	r := CheckDockerImageExists(&schema.DockerImageCheck{Image: "alpine:3.20"})
+	if !r.Passed {
+		t.Errorf("expected pass for existing image, got fail: %+v", r)
+	}
+}
