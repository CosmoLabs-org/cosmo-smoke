+package cmd
+
+import (
+	"bytes"
+	"io"
+	"os"
+	"path/filepath"
+	"strings"
+	"testing"
+)
+
+// writeGossFile creates a minimal valid Goss YAML in a temp dir and returns its path.
+func writeGossFile(t *testing.T) string {
+	t.Helper()
+	dir := t.TempDir()
+	gossYAML := `
+file:
+  /etc/passwd:
+    exists: true
+    filetype: file
+command:
+  echo hello:
+    exit-status: 0
+    stdout:
+      - hello
+`
+	path := filepath.Join(dir, "goss.yaml")
+	if err := os.WriteFile(path, []byte(gossYAML), 0644); err != nil {
+		t.Fatal(err)
+	}
+	return path
+}
+
+// captureStdout captures os.Stdout during the execution of fn.
+func captureStdout(fn func() error) (string, error) {
+	old := os.Stdout
+	r, w, _ := os.Pipe()
+	os.Stdout = w
+	err := fn()
+	w.Close()
+	os.Stdout = old
+	var buf bytes.Buffer
+	io.Copy(&buf, r)
+	return buf.String(), err
+}
+
+func resetMigrateFlags() {
+	migrateOutput = ""
+	migrateOverwrite = false
+	migrateStrict = false
+	migrateStats = false
+	migrateDistro = "deb"
+}
+
+func TestRunMigrateGoss_ValidInput(t *testing.T) {
+	inputPath := writeGossFile(t)
+	defer resetMigrateFlags()
+
+	output, err := captureStdout(func() error {
+		return runMigrateGoss(gossCmd, []string{inputPath})
+	})
+	if err != nil {
+		t.Fatalf("runMigrateGoss: %v", err)
+	}
+	if !strings.Contains(output, "tests:") && !strings.Contains(output, "- name:") {
+		t.Errorf("expected smoke config output, got: %s", output)
+	}
+}
+
+func TestRunMigrateGoss_FileNotFound(t *testing.T) {
+	defer func() { migrateDistro = "deb" }()
+
+	err := runMigrateGoss(gossCmd, []string{"/nonexistent/goss.yaml"})
+	if err == nil {
+		t.Fatal("expected error for missing input file")
+	}
+}
+
+func TestRunMigrateGoss_InvalidDistro(t *testing.T) {
+	inputPath := writeGossFile(t)
+	defer func() { migrateDistro = "deb" }()
+
+	migrateDistro = "invalid"
+	err := runMigrateGoss(gossCmd, []string{inputPath})
+	if err == nil {
+		t.Fatal("expected error for invalid distro")
+	}
+	if !strings.Contains(err.Error(), "unsupported distro") {
+		t.Errorf("error = %q, want unsupported distro", err.Error())
+	}
+}
+
+func TestRunMigrateGoss_WriteToFile(t *testing.T) {
+	inputPath := writeGossFile(t)
+	dir := t.TempDir()
+	outPath := filepath.Join(dir, ".smoke.yaml")
+	defer resetMigrateFlags()
+
+	migrateOutput = outPath
+
+	err := runMigrateGoss(gossCmd, []string{inputPath})
+	if err != nil {
+		t.Fatalf("runMigrateGoss: %v", err)
+	}
+
+	data, err := os.ReadFile(outPath)
+	if err != nil {
+		t.Fatalf("reading output file: %v", err)
+	}
+	if len(data) == 0 {
+		t.Error("output file is empty")
+	}
+}
+
+func TestRunMigrateGoss_OutputFileExists(t *testing.T) {
+	inputPath := writeGossFile(t)
+	dir := t.TempDir()
+	outPath := filepath.Join(dir, ".smoke.yaml")
+
+	if err := os.WriteFile(outPath, []byte("existing\n"), 0644); err != nil {
+		t.Fatal(err)
+	}
+	defer resetMigrateFlags()
+
+	migrateOutput = outPath
+	err := runMigrateGoss(gossCmd, []string{inputPath})
+	if err == nil {
+		t.Fatal("expected error when output file exists without --overwrite")
+	}
+	if !strings.Contains(err.Error(), "already exists") {
+		t.Errorf("error = %q, want 'already exists'", err.Error())
+	}
+}
+
+func TestRunMigrateGoss_OverwriteExisting(t *testing.T) {
+	inputPath := writeGossFile(t)
+	dir := t.TempDir()
+	outPath := filepath.Join(dir, ".smoke.yaml")
+
+	if err := os.WriteFile(outPath, []byte("existing\n"), 0644); err != nil {
+		t.Fatal(err)
+	}
+	defer resetMigrateFlags()
+
+	migrateOutput = outPath
+	migrateOverwrite = true
+
+	err := runMigrateGoss(gossCmd, []string{inputPath})
+	if err != nil {
+		t.Fatalf("runMigrateGoss with overwrite: %v", err)
+	}
+
+	data, err := os.ReadFile(outPath)
+	if err != nil {
+		t.Fatalf("reading output file: %v", err)
+	}
+	if string(data) == "existing\n" {
+		t.Error("output file was not overwritten")
+	}
+}
+
+func TestRunMigrateGoss_WithStats(t *testing.T) {
+	inputPath := writeGossFile(t)
+	defer resetMigrateFlags()
+
+	migrateStats = true
+
+	_, err := captureStdout(func() error {
+		return runMigrateGoss(gossCmd, []string{inputPath})
+	})
+	if err != nil {
+		t.Fatalf("runMigrateGoss: %v", err)
+	}
+}
