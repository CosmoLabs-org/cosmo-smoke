+package cmd
+
+import (
+	"bytes"
+	"io"
+	"os"
+	"strings"
+	"testing"
+)
+
+func TestSchemaCmd_Output(t *testing.T) {
+	// Capture os.Stdout since schemaCmd uses fmt.Println directly
+	old := os.Stdout
+	r, w, _ := os.Pipe()
+	os.Stdout = w
+
+	rootCmd.SetArgs([]string{"schema"})
+	err := rootCmd.Execute()
+
+	w.Close()
+	os.Stdout = old
+	defer func() { rootCmd.SetArgs([]string{}) }()
+
+	if err != nil {
+		t.Fatalf("schema command: %v", err)
+	}
+
+	var buf bytes.Buffer
+	io.Copy(&buf, r)
+	output := buf.String()
+	if !strings.Contains(output, "assertions") && !strings.Contains(output, "name") {
+		t.Errorf("schema output should contain JSON schema data, got: %s", output[:min(len(output), 200)])
+	}
+}
+
+func TestSchemaCmd_Registered(t *testing.T) {
+	var found bool
+	for _, sub := range rootCmd.Commands() {
+		if sub.Use == "schema" {
+			found = true
+			break
+		}
+	}
+	if !found {
+		t.Error("schema command not registered on rootCmd")
+	}
+}
