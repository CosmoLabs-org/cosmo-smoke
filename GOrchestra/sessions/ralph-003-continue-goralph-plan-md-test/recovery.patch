+package cmd
+
+import (
+	"encoding/json"
+	"net/http"
+	"net/http/httptest"
+	"strings"
+	"testing"
+
+	"github.com/CosmoLabs-org/cosmo-smoke/internal/reporter"
+	"github.com/CosmoLabs-org/cosmo-smoke/internal/schema"
+)
+
+// --- countProcessTests ---
+
+func TestCountProcessTests(t *testing.T) {
+	tests := []struct {
+		name  string
+		cfg   *schema.SmokeConfig
+		count int
+	}{
+		{
+			name:  "nil tests",
+			cfg:   &schema.SmokeConfig{},
+			count: 0,
+		},
+		{
+			name: "no port listening tests",
+			cfg: &schema.SmokeConfig{
+				Tests: []schema.Test{
+					{Name: "t1", Run: "echo hi"},
+					{Name: "t2", Run: "echo bye"},
+				},
+			},
+			count: 0,
+		},
+		{
+			name: "one port listening test",
+			cfg: &schema.SmokeConfig{
+				Tests: []schema.Test{
+					{Name: "t1", Run: "true", Expect: schema.Expect{PortListening: &schema.PortCheck{Port: 8080}}},
+				},
+			},
+			count: 1,
+		},
+		{
+			name: "mixed tests",
+			cfg: &schema.SmokeConfig{
+				Tests: []schema.Test{
+					{Name: "t1", Run: "true"},
+					{Name: "t2", Run: "true", Expect: schema.Expect{PortListening: &schema.PortCheck{Port: 80}}},
+					{Name: "t3", Run: "true"},
+					{Name: "t4", Run: "true", Expect: schema.Expect{PortListening: &schema.PortCheck{Port: 443}}},
+				},
+			},
+			count: 2,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			got := countProcessTests(tt.cfg)
+			if got != tt.count {
+				t.Errorf("countProcessTests() = %d, want %d", got, tt.count)
+			}
+		})
+	}
+}
+
+// --- writeHealthError ---
+
+func TestWriteHealthError(t *testing.T) {
+	rec := httptest.NewRecorder()
+	writeHealthError(rec, http.StatusServiceUnavailable, "something broke")
+
+	if rec.Code != http.StatusServiceUnavailable {
+		t.Errorf("status = %d, want %d", rec.Code, http.StatusServiceUnavailable)
+	}
+
+	ct := rec.Header().Get("Content-Type")
+	if !strings.Contains(ct, "json") {
+		t.Errorf("Content-Type = %q, want json", ct)
+	}
+
+	var body map[string]string
+	if err := json.NewDecoder(rec.Body).Decode(&body); err != nil {
+		t.Fatalf("decode response: %v", err)
+	}
+	if body["error"] != "something broke" {
+		t.Errorf("error = %q, want %q", body["error"], "something broke")
+	}
+}
+
+func TestWriteHealthError_InternalServerError(t *testing.T) {
+	rec := httptest.NewRecorder()
+	writeHealthError(rec, http.StatusInternalServerError, "load config: missing")
+
+	if rec.Code != http.StatusInternalServerError {
+		t.Errorf("status = %d, want %d", rec.Code, http.StatusInternalServerError)
+	}
+}
+
+// --- noopReporter ---
+
+func TestNoopReporter_AllMethods(t *testing.T) {
+	n := newNoopReporter()
+	// All methods should be callable without panicking and produce no output.
+	n.PrereqStart("test-prereq")
+	n.PrereqResult(reporter.PrereqResultData{})
+	n.TestStart("test-case")
+	n.TestResult(reporter.TestResultData{})
+	n.Summary(reporter.SuiteResultData{})
+}
+
+// --- withOTelExport ---
+
+func TestWithOTelExport_Disabled(t *testing.T) {
+	cfg := &schema.SmokeConfig{OTel: schema.OTelConfig{}}
+	rep := withOTelExport(&testReporter{}, cfg)
+	if rep == nil {
+		t.Error("expected non-nil reporter")
+	}
+	// Should return the original reporter unchanged (wrapped or same)
+	_, ok := rep.(*testReporter)
+	if !ok {
+		// It might be wrapped, that's fine — the key is no panic and no nil
+		t.Log("reporter was wrapped (acceptable)")
+	}
+}
+
