 	_ = r
 }
+
+// ---------------------------------------------------------------------------
+// CheckPortListening
+// ---------------------------------------------------------------------------
+
+func TestCheckPortListening_Fail(t *testing.T) {
+	r := CheckPortListening(59999, "tcp", "localhost")
+	if r.Passed {
+		t.Errorf("expected fail for closed port")
+	}
+	if r.Type != "port_listening" {
+		t.Errorf("expected type 'port_listening', got %q", r.Type)
+	}
+}
