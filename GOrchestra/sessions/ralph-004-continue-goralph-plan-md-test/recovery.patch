+package reporter
+
+import (
+	"bytes"
+	"strings"
+	"testing"
+	"time"
+)
+
+// recordingReporter captures all calls for verification.
+type recordingReporter struct {
+	prereqStarts  []string
+	prereqResults []PrereqResultData
+	testStarts    []string
+	testResults   []TestResultData
+	summaries     []SuiteResultData
+}
+
+func (r *recordingReporter) PrereqStart(name string)          { r.prereqStarts = append(r.prereqStarts, name) }
+func (r *recordingReporter) PrereqResult(data PrereqResultData) { r.prereqResults = append(r.prereqResults, data) }
+func (r *recordingReporter) TestStart(name string)            { r.testStarts = append(r.testStarts, name) }
+func (r *recordingReporter) TestResult(data TestResultData)   { r.testResults = append(r.testResults, data) }
+func (r *recordingReporter) Summary(data SuiteResultData)     { r.summaries = append(r.summaries, data) }
+
+func TestMultiReporter_FansOutAllEvents(t *testing.T) {
+	rec1 := &recordingReporter{}
+	rec2 := &recordingReporter{}
+	m := NewMultiReporter(rec1, rec2)
+
+	m.PrereqStart("check-docker")
+	m.PrereqResult(PrereqResultData{Name: "check-docker", Passed: true})
+	m.TestStart("health")
+	m.TestResult(TestResultData{Name: "health", Passed: true, Duration: 10 * time.Millisecond})
+	m.Summary(SuiteResultData{Project: "test", Total: 1, Passed: 1})
+
+	// Verify both reporters received all events
+	for i, rec := range []*recordingReporter{rec1, rec2} {
+		if len(rec.prereqStarts) != 1 || rec.prereqStarts[0] != "check-docker" {
+			t.Errorf("reporter %d: prereqStarts = %v, want [check-docker]", i, rec.prereqStarts)
+		}
+		if len(rec.prereqResults) != 1 || !rec.prereqResults[0].Passed {
+			t.Errorf("reporter %d: prereqResults = %v, want one passed", i, rec.prereqResults)
+		}
+		if len(rec.testStarts) != 1 || rec.testStarts[0] != "health" {
+			t.Errorf("reporter %d: testStarts = %v, want [health]", i, rec.testStarts)
+		}
+		if len(rec.testResults) != 1 || !rec.testResults[0].Passed {
+			t.Errorf("reporter %d: testResults = %v, want one passed", i, rec.testResults)
+		}
+		if len(rec.summaries) != 1 || rec.summaries[0].Project != "test" {
+			t.Errorf("reporter %d: summaries = %v, want project=test", i, rec.summaries)
+		}
+	}
+}
+
+func TestMultiReporter_SingleReporter(t *testing.T) {
+	rec := &recordingReporter{}
+	m := NewMultiReporter(rec)
+
+	m.TestStart("solo")
+	m.TestResult(TestResultData{Name: "solo", Passed: true})
+
+	if len(rec.testStarts) != 1 {
+		t.Errorf("expected 1 test start, got %d", len(rec.testStarts))
+	}
+}
+
+func TestMultiReporter_ThreeReporters(t *testing.T) {
+	rec1 := &recordingReporter{}
+	rec2 := &recordingReporter{}
+	rec3 := &recordingReporter{}
+	m := NewMultiReporter(rec1, rec2, rec3)
+
+	m.TestStart("triple")
+
+	for i, rec := range []*recordingReporter{rec1, rec2, rec3} {
+		if len(rec.testStarts) != 1 {
+			t.Errorf("reporter %d: expected 1 test start, got %d", i, len(rec.testStarts))
+		}
+	}
+}
+
+func TestMultiReporter_WithRealReporters(t *testing.T) {
+	var buf1, buf2 bytes.Buffer
+	json1 := NewJSON(&buf1)
+	tap := NewTAP(&buf2)
+	m := NewMultiReporter(json1, tap)
+
+	m.TestStart("api")
+	m.TestResult(TestResultData{
+		Name:   "api",
+		Passed: true,
+		Assertions: []AssertionDetail{
+			{Type: "exit_code", Expected: "0", Actual: "0", Passed: true},
+		},
+		Duration: 50 * time.Millisecond,
+	})
+	m.Summary(SuiteResultData{Project: "real", Total: 1, Passed: 1})
+
+	// JSON reporter should have produced output in Summary
+	if buf1.String() == "" {
+		t.Error("expected JSON output from first reporter")
+	}
+	// TAP reporter should have produced output in Summary
+	if !strings.Contains(buf2.String(), "TAP version 14") {
+		t.Error("expected TAP output from second reporter")
+	}
+}
+
+func TestMultiReporter_PrereqResult(t *testing.T) {
+	rec := &recordingReporter{}
+	m := NewMultiReporter(rec)
+
+	data := PrereqResultData{
+		Name:   "check-redis",
+		Passed: false,
+		Output: "connection refused",
+		Hint:   "start redis",
+		Error:  nil,
+	}
+	m.PrereqResult(data)
+
+	if len(rec.prereqResults) != 1 {
+		t.Fatalf("expected 1 prereq result, got %d", len(rec.prereqResults))
+	}
+	got := rec.prereqResults[0]
+	if got.Name != "check-redis" || got.Passed || got.Output != "connection refused" || got.Hint != "start redis" {
+		t.Errorf("PrereqResult not forwarded correctly: %+v", got)
+	}
+}
+
+func TestMultiReporter_TestResult(t *testing.T) {
+	rec := &recordingReporter{}
+	m := NewMultiReporter(rec)
+
+	data := TestResultData{
+		Name:           "flaky",
+		Passed:         false,
+		AllowedFailure: true,
+		Duration:       100 * time.Millisecond,
+		Assertions: []AssertionDetail{
+			{Type: "http_status", Expected: "200", Actual: "503", Passed: false},
+		},
+	}
+	m.TestResult(data)
+
+	if len(rec.testResults) != 1 {
+		t.Fatalf("expected 1 test result, got %d", len(rec.testResults))
+	}
+	got := rec.testResults[0]
+	if got.Name != "flaky" || !got.AllowedFailure {
+		t.Errorf("TestResult not forwarded correctly: %+v", got)
+	}
+}
+
+func TestMultiReporter_Summary(t *testing.T) {
+	rec := &recordingReporter{}
+	m := NewMultiReporter(rec)
+
+	data := SuiteResultData{
+		Project:         "multi-test",
+		Total:           5,
+		Passed:          3,
+		Failed:          1,
+		Skipped:         1,
+		AllowedFailures: 0,
+		Duration:        2 * time.Second,
+		TraceHealthPct:  85.5,
+		TraceDegraded:   false,
+	}
+	m.Summary(data)
+
+	if len(rec.summaries) != 1 {
+		t.Fatalf("expected 1 summary, got %d", len(rec.summaries))
+	}
+	got := rec.summaries[0]
+	if got.Project != "multi-test" || got.Total != 5 || got.Passed != 3 {
+		t.Errorf("Summary not forwarded correctly: %+v", got)
+	}
+	if got.TraceHealthPct != 85.5 {
+		t.Errorf("TraceHealthPct = %v, want 85.5", got.TraceHealthPct)
+	}
+}
