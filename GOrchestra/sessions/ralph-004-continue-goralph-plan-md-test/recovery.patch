+package runner
+
+import (
+	"encoding/binary"
+	"io"
+	"net"
+	"testing"
+)
+
+// wsPipe creates a pair of connected net.Conns using a real TCP listener.
+func wsPipe(t *testing.T) (client, server net.Conn) {
+	t.Helper()
+	ln, err := net.Listen("tcp", "127.0.0.1:0")
+	if err != nil {
+		t.Fatal(err)
+	}
+	t.Cleanup(func() { ln.Close() })
+
+	ch := make(chan net.Conn)
+	go func() {
+		conn, err := ln.Accept()
+		if err != nil {
+			close(ch)
+			return
+		}
+		ch <- conn
+	}()
+
+	client, err = net.Dial("tcp", ln.Addr().String())
+	if err != nil {
+		t.Fatal(err)
+	}
+	server = <-ch
+	if server == nil {
+		t.Fatal("server accept failed")
+	}
+	t.Cleanup(func() { client.Close() })
+	t.Cleanup(func() { server.Close() })
+	return client, server
+}
+
+// writeTextFrame writes a raw WebSocket text frame (unmasked, server-to-client).
+func writeTextFrame(conn net.Conn, payload string) {
+	frame := []byte{0x81} // FIN + text opcode
+	n := len(payload)
+	if n <= 125 {
+		frame = append(frame, byte(n))
+	} else if n <= 65535 {
+		frame = append(frame, 126, byte(n>>8), byte(n))
+	}
+	frame = append(frame, []byte(payload)...)
+	conn.Write(frame)
+}
+
+// writeCloseFrame writes a WebSocket close frame with optional reason.
+func writeCloseFrame(conn net.Conn, reason string) {
+	frame := []byte{0x88} // FIN + close opcode
+	n := len(reason)
+	if n <= 125 {
+		frame = append(frame, byte(n))
+	}
+	frame = append(frame, []byte(reason)...)
+	conn.Write(frame)
+}
+
+// writePingFrame writes a WebSocket ping frame with optional payload.
+func writePingFrame(conn net.Conn, payload string) {
+	frame := []byte{0x89} // FIN + ping opcode
+	frame = append(frame, byte(len(payload)))
+	frame = append(frame, []byte(payload)...)
+	conn.Write(frame)
+}
+
+func TestWsReadFrame_TextFrame(t *testing.T) {
+	client, server := wsPipe(t)
+	writeTextFrame(server, "hello")
+	msg, closed, err := wsReadFrame(client)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if closed {
+		t.Error("expected closed=false for text frame")
+	}
+	if msg != "hello" {
+		t.Errorf("msg = %q, want %q", msg, "hello")
+	}
+}
+
+func TestWsReadFrame_EmptyTextFrame(t *testing.T) {
+	client, server := wsPipe(t)
+	writeTextFrame(server, "")
+	msg, closed, err := wsReadFrame(client)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if closed {
+		t.Error("expected closed=false for empty text frame")
+	}
+	if msg != "" {
+		t.Errorf("msg = %q, want empty", msg)
+	}
+}
+
+func TestWsReadFrame_CloseFrame_WithReason(t *testing.T) {
+	client, server := wsPipe(t)
+	writeCloseFrame(server, "going away")
+	msg, closed, err := wsReadFrame(client)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if !closed {
+		t.Error("expected closed=true for close frame")
+	}
+	if msg != "going away" {
+		t.Errorf("msg = %q, want %q", msg, "going away")
+	}
+}
+
+func TestWsReadFrame_CloseFrame_Empty(t *testing.T) {
+	client, server := wsPipe(t)
+	frame := []byte{0x88, 0x00} // FIN + close, length 0
+	server.Write(frame)
+	msg, closed, err := wsReadFrame(client)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if !closed {
+		t.Error("expected closed=true for empty close frame")
+	}
+	if msg != "" {
+		t.Errorf("msg = %q, want empty for empty close frame", msg)
+	}
+}
+
+func TestWsReadFrame_PingFrame_WithPayload(t *testing.T) {
+	client, server := wsPipe(t)
+	writePingFrame(server, "ping-data")
+	msg, closed, err := wsReadFrame(client)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if closed {
+		t.Error("expected closed=false for ping frame")
+	}
+	// Ping returns empty string (payload is consumed but not returned)
+	if msg != "" {
+		t.Errorf("msg = %q, want empty for ping frame", msg)
+	}
+}
+
+func TestWsReadFrame_PingFrame_Empty(t *testing.T) {
+	client, server := wsPipe(t)
+	frame := []byte{0x89, 0x00} // FIN + ping, length 0
+	server.Write(frame)
+	msg, closed, err := wsReadFrame(client)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if closed {
+		t.Error("expected closed=false for ping frame")
+	}
+	if msg != "" {
+		t.Errorf("msg = %q, want empty for empty ping", msg)
+	}
+}
+
+func TestWsReadFrame_ExtendedPayload16Bit(t *testing.T) {
+	client, server := wsPipe(t)
+	// Build a text frame with 126 (16-bit length prefix)
+	payload := make([]byte, 200)
+	for i := range payload {
+		payload[i] = 'A' + byte(i%26)
+	}
+	frame := []byte{0x81, 126}
+	frame = append(frame, byte(200>>8), byte(200))
+	frame = append(frame, payload...)
+	server.Write(frame)
+
+	msg, closed, err := wsReadFrame(client)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if closed {
+		t.Error("expected closed=false")
+	}
+	if len(msg) != 200 {
+		t.Errorf("len(msg) = %d, want 200", len(msg))
+	}
+}
+
+func TestWsReadFrame_ExtendedPayload64Bit(t *testing.T) {
+	client, server := wsPipe(t)
+	// Build a text frame with 127 (64-bit length prefix)
+	payload := make([]byte, 300)
+	for i := range payload {
+		payload[i] = 'x'
+	}
+	frame := []byte{0x81, 127}
+	lenBytes := make([]byte, 8)
+	binary.BigEndian.PutUint64(lenBytes, 300)
+	frame = append(frame, lenBytes...)
+	frame = append(frame, payload...)
+	server.Write(frame)
+
+	msg, closed, err := wsReadFrame(client)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if closed {
+		t.Error("expected closed=false")
+	}
+	if len(msg) != 300 {
+		t.Errorf("len(msg) = %d, want 300", len(msg))
+	}
+}
+
+func TestWsReadFrame_MaskedFrame(t *testing.T) {
+	client, server := wsPipe(t)
+	// Build a masked text frame
+	payload := []byte("hello")
+	mask := []byte{0x37, 0xfa, 0x21, 0x3d}
+	masked := make([]byte, len(payload))
+	for i, b := range payload {
+		masked[i] = b ^ mask[i%4]
+	}
+	frame := []byte{0x81, 0x80 | byte(len(payload))} // FIN + text, masked, length
+	frame = append(frame, mask...)
+	frame = append(frame, masked...)
+	server.Write(frame)
+
+	// wsReadFrame skips the mask key but doesn't unmask the payload
+	// (server frames shouldn't be masked, but the code handles it)
+	msg, closed, err := wsReadFrame(client)
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if closed {
+		t.Error("expected closed=false")
+	}
+	// The payload is read but not unmasked, so we get the masked bytes
+	if msg == "" {
+		t.Error("expected non-empty message (masked payload was consumed)")
+	}
+}
+
+func TestWsReadFrame_ConnectionClosed(t *testing.T) {
+	client, server := wsPipe(t)
+	server.Close()
+	_, _, err := wsReadFrame(client)
+	if err == nil {
+		t.Error("expected error when connection closed")
+	}
+}
+
+func TestWsSendMessage_ShortMessage(t *testing.T) {
+	client, server := wsPipe(t)
+	err := wsSendMessage(client, "hi")
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+
+	// Read the frame from the server side
+	buf := make([]byte, 256)
+	n, _ := server.Read(buf)
+	frame := buf[:n]
+
+	// Check FIN + text opcode
+	if frame[0] != 0x81 {
+		t.Errorf("first byte = 0x%02x, want 0x81 (FIN+text)", frame[0])
+	}
+	// Check masked bit set + length
+	if frame[1]&0x80 == 0 {
+		t.Error("expected masked bit set")
+	}
+	if frame[1]&0x7F != 2 {
+		t.Errorf("payload length = %d, want 2", frame[1]&0x7F)
+	}
+}
+
+func TestWsSendMessage_MediumMessage(t *testing.T) {
+	client, server := wsPipe(t)
+	// 200 bytes → uses 16-bit extended length
+	msg := make([]byte, 200)
+	for i := range msg {
+		msg[i] = 'B'
+	}
+	err := wsSendMessage(client, string(msg))
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+
+	buf := make([]byte, 512)
+	n, _ := server.Read(buf)
+	frame := buf[:n]
+
+	if frame[1]&0x7F != 126 {
+		t.Errorf("expected extended 16-bit length indicator (126), got %d", frame[1]&0x7F)
+	}
+}
+
+func TestWsSendMessage_EmptyMessage(t *testing.T) {
+	client, server := wsPipe(t)
+	err := wsSendMessage(client, "")
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+
+	buf := make([]byte, 32)
+	n, _ := server.Read(buf)
+	frame := buf[:n]
+
+	if frame[1]&0x7F != 0 {
+		t.Errorf("payload length = %d, want 0", frame[1]&0x7F)
+	}
+}
+
+func TestWsSendMessage_ConnectionClosed(t *testing.T) {
+	client, server := wsPipe(t)
+	server.Close()
+	// Write until we get an error (buffer may accept some writes)
+	var err error
+	for i := 0; i < 100; i++ {
+		err = wsSendMessage(client, "test")
+		if err != nil {
+			break
+		}
+	}
+	if err == nil {
+		// May or may not error depending on OS buffering — acceptable
+		t.Log("no error on closed connection (OS buffered writes)")
+	}
+	_ = io.EOF // suppress import if needed
+}
